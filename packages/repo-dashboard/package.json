{
  "name": "repo-dashboard",
  "version": "0.1.0",
  "description": "CLI dashboard for GitHub repositories \u2014 PRs, pipelines, issues at a glance",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "repo-dash": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run"
